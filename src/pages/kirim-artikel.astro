---
// src/pages/kirim-artikel.astro
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kirim Artikel Komunitas - Hattrick</title>
  <!-- 1. TAMBAHKAN SCRIPT TURNSTILE DI SINI -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body>

  <main class="main-container">
    <section class="syarat-box">
      <h1>Kirim Artikel Komunitas Hattrick</h1>
      <p>Pastikan tulisanmu memenuhi syarat kebijakan komunitas sebelum mengirim.</p>
    </section>

    <section class="form-box">
      <h2>Mulai Menulis</h2>
      
      <form id="artikelForm">
        <div class="input-group">
          <label for="nama">Nama Pena / Penulis</label>
          <input type="text" id="nama" required placeholder="Masukkan nama panggilan atau nama penamu" autocomplete="off">
        </div>

        <div class="input-group">
          <label for="judul">Usulan Judul Artikel</label>
          <input type="text" id="judul" required placeholder="Tulis judul bebas sesuai ide tulisanmu" autocomplete="off">
        </div>

        <div class="input-group">
          <label for="isi">Isi Artikel / Tulisan Kasar</label>
          <textarea id="isi" rows="12" required placeholder="Tulis atau tempel naskah artikelmu secara lengkap di sini..."></textarea>
        </div>

        <!-- 2. TAMBAHKAN WIDGET TURNSTILE DI SINI -->
        <!-- Ganti 'YOUR_TURNSTILE_SITE_KEY' dengan Site Key dari Cloudflare kamu -->
        <div class="cf-turnstile" data-sitekey="0x4AAAAAAD44uKz3jL8-Ij-0" style="margin-bottom: 20px;"></div>

        <button type="submit" id="btnKirim">Kirim Artikel ke Editor</button>
      </form>
    </section>
  </main>

  <script>
    document.getElementById('artikelForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const btn = document.getElementById('btnKirim');
      if (!btn) return; 

      btn.disabled = true;
      btn.innerText = 'Sedang Mengirim Naskah...';

      // 3. AMBIL TOKEN TURNSTILE DARI FORM
      const formData = new FormData(e.target as HTMLFormElement);
      const turnstileToken = formData.get('cf-turnstile-response');

      const payload = {
        nama: (document.getElementById('nama') as HTMLInputElement).value,
        judul: (document.getElementById('judul') as HTMLInputElement).value,
        isi: (document.getElementById('isi') as HTMLTextAreaElement).value,
        token: turnstileToken // Token disisipkan ke payload
      };

      try {
        const response = await fetch('https://hattrick-worker.anditoinfo.workers.dev', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (response.ok && result.success) {
          alert('Berhasil! ' + result.message);
          (e.target as HTMLFormElement).reset();
        } else {
          alert('Gagal mengirim: ' + (result.message || 'Terjadi kesalahan backend.'));
        }
      } catch (error) {
        alert('Gagal terhubung ke Worker lokal.');
      } finally {
        btn.disabled = false;
        btn.innerText = 'Kirim Artikel ke Editor';
        // Reset widget Turnstile agar bisa digunakan lagi tanpa reload halaman
        if ((window as any).turnstile) {
          (window as any).turnstile.reset();
        }
      }
    });
  </script>

</body>
</html>

<!-- Bagian 4: CSS Styling (Scoped ke Halaman Ini) -->
<style>
  :root {
    --primary-color: #003366;
    --accent-color: #ff6600;
    --text-color: #2c3e50;
    --bg-light: #f8f9fa;
    --border-color: #dcdde1;
  }

  body {
    font-family: Arial, sans-serif;
    background-color: #f1f2f6;
    color: var(--text-color);
    margin: 0;
    padding: 0;
    line-height: 1.6;
  }

  .main-container {
    max-width: 750px;
    margin: 40px auto;
    padding: 0 20px;
  }

  /* Styling Box Syarat Ketentuan */
  .syarat-box {
    background: #ffffff;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    margin-bottom: 25px;
    border-top: 5px solid var(--accent-color);
  }

  .syarat-box h1 {
    color: var(--primary-color);
    font-size: 24px;
    margin-top: 0;
    margin-bottom: 15px;
  }

  .syarat-box p {
    font-size: 15px;
    color: #57606f;
  }

  .syarat-box ul {
    padding-left: 20px;
    margin-bottom: 20px;
  }

  .syarat-box li {
    font-size: 14.5px;
    margin-bottom: 10px;
  }

  .info-note {
    background-color: var(--bg-light);
    border-left: 4px solid #747d8c;
    padding: 5px 15px;
    font-size: 13.5px;
    border-radius: 0 4px 4px 0;
  }

  /* Styling Box Form Input */
  .form-box {
    background: #ffffff;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .form-box h2 {
    color: var(--primary-color);
    font-size: 20px;
    margin-top: 0;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--bg-light);
    padding-bottom: 10px;
  }

  .input-group {
    margin-bottom: 20px;
  }

  .input-group label {
    display: block;
    font-weight: bold;
    font-size: 14px;
    margin-bottom: 8px;
    color: var(--primary-color);
  }

  .input-group input,
  .input-group textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 14.5px;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .input-group input:focus,
  .input-group textarea:focus {
    outline: none;
    border-color: var(--primary-color);
  }

  .input-group textarea {
    resize: vertical;
    font-family: inherit;
  }

  /* Styling Tombol Submit */
  button[type="submit"] {
    width: 100%;
    padding: 14px;
    background-color: var(--primary-color);
    color: #ffffff;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  button[type="submit"]:hover {
    background-color: #002244;
  }

  button[type="submit"]:disabled {
    background-color: #a4b0be;
    cursor: not-allowed;
  }
</style>