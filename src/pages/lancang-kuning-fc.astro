---
// src/pages/lancang-kuning-fc.astro
import Navbar from '../components/Navbar.astro';
const clubData = {
  name: "LANCANG KUNING FC",
  motto: "Setiap musim adalah pelayaran, setiap pertandingan adalah ombak yang harus dihadapi.",
  info: {
    manager: "Andhim",
    founded: "28 Juli 2022",
    location: "Pekanbaru, Riau, Indonesia",
    stadium: "Gelanggang Bertuah",
    capacity: "46.000",
    academy: "SS Pekanbaru",
  },
  philosophy:
    "Seperti sebuah kapal yang berlayar menghadapi badai di lautan, klub ini percaya bahwa setiap musim membawa tantangan baru yang harus dilalui bersama. Kemenangan bukan sekadar tujuan, melainkan hasil dari proses belajar, kerja sama, dan ketekunan. Kekalahan bukan akhir perjalanan, tetapi pelajaran untuk berlayar lebih baik pada musim berikutnya.",
  whatsapp: "6281268480808",
};

const waMessage = encodeURIComponent(
  "Halo Manajer Andhim! Saya ingin berdiskusi / menantang friendly match dengan Lancang Kuning FC."
);
const waLink = `https://wa.me/${clubData.whatsapp}?text=${waMessage}`;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{clubData.name} - Profil Klub Official</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-wrapper">
      <!-- Background Decorative Elements -->
      <div class="bg-glow"></div>

      <main class="container">
        <!-- Hero / Badge Header -->
        <header class="club-header">
          <div class="badge-container">
            <!-- SVG Logo Kapal Lancang Kuning -->
            <svg class="club-badge" viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 5 L90 25 V70 C90 95 50 115 50 115 C50 115 10 95 10 70 V25 L50 5Z" fill="#111827" stroke="#FACC15" stroke-width="4"/>
              <!-- Kapal / Waves Symbol -->
              <path d="M25 75 C40 68 60 82 75 75 C70 88 30 88 25 75 Z" fill="#FACC15"/>
              <path d="M50 25 V65 M50 30 L70 42 H50" stroke="#FACC15" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M20 83 C35 78 65 88 80 83" stroke="#22C55E" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </div>
          <h1 class="club-title">{clubData.name}</h1>
          <p class="club-motto">"{clubData.motto}"</p>
        </header>

        <!-- Main Grid Info -->
        <div class="grid-layout">
          <!-- Card Informasi Klub -->
          <section class="card info-card">
            <div class="card-header">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <h2> Club Overview</h2>
            </div>
            <ul class="info-list">
              <li>
                <span class="label">Manager</span>
                <span class="valueHighlight">{clubData.info.manager}</span>
              </li>
              <li>
                <span class="label">Founded</span>
                <span class="value">{clubData.info.founded}</span>
              </li>
              <li>
                <span class="label">Home Base</span>
                <span class="value">{clubData.info.location}</span>
              </li>
              <li>
                <span class="label">Stadium</span>
                <span class="value">{clubData.info.stadium}</span>
              </li>
              <li>
                <span class="label">Capacity</span>
                <span class="value">{clubData.info.capacity} Penonton</span>
              </li>
              <li>
                <span class="label">Youth Academy</span>
                <span class="valueHighlight">{clubData.info.academy}</span>
              </li>
            </ul>
          </section>

          <!-- Card Filosofi Klub -->
          <section class="card philosophy-card">
            <div class="card-header">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
              </svg>
              <h2>CLUB PHILOSOPHY</h2>
            </div>
            <p class="philosophy-text">{clubData.philosophy}</p>
          </section>
        </div>

        <!-- Section Kontak & Call To Action -->
        <section class="cta-section">
          <h3>Contact Manager</h3>
          <p>Challenging for a Friendly Match?  </p>
          
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            <!-- SVG WhatsApp Icon -->
            <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
            </svg>
            <span>Contact via WhatsApp</span>
          </a>
        </section>

        <!-- Footer Ringkas -->
        <footer class="club-footer">
  <p class="explore-text">
    Jelajahi artikel & komunitas di <a href="/" class="footer-link">Beranda Utama hattrick.web.id &rarr;</a>
  </p>
  <p class="copyright">
    &copy; {new Date().getFullYear()} Lancang Kuning FC
  </p>
</footer>
      </main>
    </div>
  </body>
</html>

<style>
  /* RESET & BASE STYLES */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    /* Ubah background ke nuansa Hijau Stadion yang kaya & segar */
    background: #064e3b;
    background: linear-gradient(135deg, #022c22 0%, #065f46 50%, #047857 100%);
    color: #f8fafc;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .page-wrapper {
    position: relative;
    padding: 2.5rem 1rem;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* BACKGROUND GLOW EFFECT (Aura Kuning Emas & Hijau Terang) */
  .bg-glow {
    position: absolute;
    top: 5%;
    left: 50%;
    transform: translateX(-50%);
    width: 650px;
    height: 650px;
    background: radial-gradient(circle, rgba(250, 204, 21, 0.25) 0%, rgba(34, 197, 94, 0.15) 45%, transparent 70%);
    filter: blur(90px);
    z-index: 0;
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 850px;
    width: 100%;
    margin: 0 auto;
  }

  /* HEADER & BADGE */
  .club-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .badge-container {
    width: 110px;
    height: 130px;
    margin: 0 auto 1.25rem;
    filter: drop-shadow(0 12px 20px rgba(250, 204, 21, 0.4));
    transition: transform 0.3s ease;
  }

  .badge-container:hover {
    transform: translateY(-5px) scale(1.04);
  }

  .club-title {
    font-family: 'Cinzel', serif;
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    /* Gradasi Judul Kuning Emas Terang */
    background: linear-gradient(135deg, #ffffff 20%, #facc15 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.75rem;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .club-motto {
    font-style: italic;
    color: #fef08a; /* Kuning soft agar kontras dan mudah dibaca */
    font-size: 1.05rem;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 500;
  }

  /* GRID LAYOUT */
  .grid-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  /* CARDS MODERN STYLING (Background Hijau Gelap dengan Border Kuning) */
  .card {
    background: rgba(6, 78, 59, 0.65);
    border: 1px solid rgba(250, 204, 21, 0.3);
    backdrop-filter: blur(16px);
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 20px 30px rgba(0, 0, 0, 0.25);
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: rgba(250, 204, 21, 0.7);
    box-shadow: 0 20px 35px rgba(250, 204, 21, 0.15);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(250, 204, 21, 0.2);
  }

  .card-header .icon {
    width: 24px;
    height: 24px;
    color: #facc15;
  }

  .card-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.5px;
  }

  /* INFO LIST */
  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .info-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
  }

  .info-list .label {
    color: #a7f3d0; /* Hijau mint terang */
  }

  .info-list .value {
    color: #ffffff;
    font-weight: 600;
  }

  .info-list .valueHighlight {
    color: #facc15; /* Kuning Emas */
    font-weight: 700;
  }

  /* FILOSOFI TEXT */
  .philosophy-text {
    color: #ecfdf5;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  /* CTA SECTION (Nuansa Kuning-Hijau Cerah) */
  .cta-section {
    background: linear-gradient(135deg, rgba(6, 78, 59, 0.9) 0%, rgba(202, 138, 4, 0.25) 100%);
    border: 1px solid rgba(250, 204, 21, 0.4);
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    margin-bottom: 2rem;
    box-shadow: 0 15px 25px rgba(0, 0, 0, 0.2);
  }

  .cta-section h3 {
    font-size: 1.3rem;
    color: #ffffff;
    margin-bottom: 0.5rem;
  }

  .cta-section p {
    color: #d1fae5;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  /* BUTTON WHATSAPP (Tombol Kuning Emas dengan Teks Hijau Tua agar pop-out) */
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background-color: #facc15;
    color: #064e3b;
    font-weight: 800;
    font-size: 1rem;
    padding: 0.9rem 1.85rem;
    border-radius: 50px;
    text-decoration: none;
    box-shadow: 0 10px 20px rgba(250, 204, 21, 0.3);
    transition: all 0.3s ease;
  }

  .btn-whatsapp:hover {
    background-color: #fde047;
    color: #022c22;
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 15px 25px rgba(250, 204, 21, 0.45);
  }

  .wa-icon {
    width: 22px;
    height: 22px;
    fill: currentColor;
  }

  /* FOOTER (Opsi 2: Beranda Utama + Copyright) */
  .club-footer {
    text-align: center;
    padding-top: 0.5rem;
  }

  .explore-text {
    font-size: 0.95rem;
    margin-bottom: 0.35rem;
    color: #d1fae5;
  }

  .footer-link {
    color: #facc15;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .footer-link:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  .copyright {
    color: #6ee7b7;
    font-size: 0.825rem;
    opacity: 0.8;
  }

  /* RESPONSIVE DESIGN (MOBILE FRIENDLY) */
  @media (max-width: 768px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }

    .club-title {
      font-size: 2rem;
    }

    .card {
      padding: 1.35rem;
    }

    .cta-section {
      padding: 1.5rem 1rem;
    }
  }
</style>