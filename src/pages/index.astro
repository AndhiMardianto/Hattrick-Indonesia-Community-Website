---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactSocial from '../components/ContactSocial.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
---

<Layout title="Beranda" description="Jurnal Analisis Taktis dan Panduan Strategi Game Manager Hattrick Indonesia.">
  
  <header class="hero-banner" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/banner.webp');">
  </header>

  <Navbar />
  
  <section class="main-title-section">
    <div class="container hero-text">
      <h1>Komunitas Hattrick Manager Indonesia</h1>
      <p>Hattrick bukan sekadar tentang menang dan kalah, Hattrick adalah tentang strategi, kesabaran, persahabatan, dan perjalanan panjang membangun klub impian.</p>
      <p>Komunitas kecil ini hadir sebagai tempat berbagi pengalaman, serta cerita-cerita menarik dan konyol dari para manajer.</p>
    </div>
  </section>

  <main id="main-content" class="container main-layout">
    <section class="search-section" aria-label="🔍Cari Artikel... Pencarian Artikel">
      <input type="text" id="search-input" placeholder="Ketik kata kunci, kategori..." aria-label="Cari  " />
    </section>

    <section class="articles-section" aria-label="Daftar Artikel">
      <div class="articles-grid" id="articles-container">
        {allPosts.map((post) => (
          <article class="article-card" data-title={post.data.title.toLowerCase()} data-tags={post.data.tags.join(',').toLowerCase()}>
          <img 
  src={post.data.thumbnail} 
  alt={`Thumbnail postingan ${post.data.title}`} 
  class="card-thumb" 
  loading="lazy"
  decoding="async"
  width="360"
  height="180"
/>
            <div class="card-body">
              <div class="tags-wrapper">
                {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
              </div>
              <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
              
              <div class="meta-author">
                Oleh: <strong>{post.data.author}</strong>
              </div>

              <p>{post.data.description}</p>
              
              <div class="read-more-wrapper">
                <a 
                  href={`/blog/${post.id}`} 
                  class="read-more-btn" 
                  aria-label={`Baca selengkapnya mengenai ${post.data.title}`}
                >
                  Baca Selengkapnya
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <p id="no-results" style="display: none; text-align: center; margin: 2rem 0; color: var(--color-muted);">Artikel yang Anda cari tidak ditemukan.</p>
    </section>
  </main>

  <ContactSocial />
  <Footer />
</Layout>

<script is:inline>
  const searchInput = document.getElementById('search-input');
  const articles = document.querySelectorAll('.article-card');
  const noResults = document.getElementById('no-results');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      let hasMatches = false;

      articles.forEach(article => {
        const title = article.getAttribute('data-title');
        const tags = article.getAttribute('data-tags');

        if (title.includes(query) || tags.includes(query)) {
          article.style.display = 'block';
          hasMatches = true;
        } else {
          article.style.display = 'none';
        }
      });

      noResults.style.display = hasMatches ? 'none' : 'block';
    });
  }
</script>

<style>
  /* Banner atas murni gambar tanpa flexbox yang merusak posisi */
  .hero-banner { 
    height: 160px; 
    background-size: cover; 
    background-position: center; 
    position: relative;
    clear: both;
  }  

  /* Area khusus teks judul di bawah Navbar */
  .main-title-section {
    padding: 2.5rem 0 1rem 0;
    text-align: center;
    background: transparent;
  }

  /* Modifikasi warna teks h1 menjadi gelap agar terbaca jelas di background putih */
  .hero-text h1 { 
    font-size: 1.8rem; 
    font-weight: 800; 
    margin-bottom: 0.75rem; 
    padding: 0 1rem; 
    color: #111827; /* Hitam pekat elegan */
  }

  .hero-text p {
    color: var(--color-muted);
    max-width: 700px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.6;
    padding: 0 1rem;
  }
  
  @media (min-width: 768px) {
    .hero-banner { height: 200px; } /* Sedikit lebih tinggi di desktop */
    .hero-text h1 { font-size: 2.5rem; padding: 0; }
    .hero-text p { padding: 0; }
  }

  .main-layout { padding-top: 2rem; padding-bottom: 4rem; }
  
  .search-section input { 
    width: 100%; 
    padding: 1rem; 
    font-size: 1.1rem; 
    border: 2px solid var(--color-border); 
    border-radius: 0.5rem; 
    margin-bottom: 2.5rem; 
  }
  
  .articles-grid { 
    display: grid; 
    grid-template-columns: 1fr; 
    gap: 2rem; 
  }
  
  @media (min-width: 640px) {
    .articles-grid { grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
  }

  .article-card { border: 1px solid var(--color-border); border-radius: 0.5rem; overflow: hidden; background: white; display: flex; flex-direction: column; }
  .card-thumb { width: 100%; height: 180px; object-fit: cover; }
  
  .card-body { 
    padding: 1.5rem; 
    display: flex; 
    flex-direction: column; 
    flex-grow: 1; 
  }
  
  .tags-wrapper { margin-bottom: 0.5rem; }
  .tag { font-size: 0.8rem; font-weight: bold; color: var(--color-primary); margin-right: 0.5rem; }
  
  .card-body h3 a { color: var(--color-text); text-decoration: none; font-size: 1.3rem; }
  .card-body h3 a:hover { color: var(--color-primary); }
  
  .meta-author {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .card-body p { color: var(--color-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  
  .read-more-wrapper {
    margin-top: auto; 
  }

  .read-more-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    border-radius: 0.25rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .read-more-btn:hover {
    background-color: var(--color-primary);
    color: #ffffff;
  }
</style>